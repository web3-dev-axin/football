{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@polygoal/shared": [
        "packages/shared/src/index.ts"
      ],
      "@polygoal/shared/*": [
        "packages/shared/src/*"
      ],
      "@polygoal/config": [
        "packages/config/src/index.ts"
      ],
      "@polygoal/config/*": [
        "packages/config/src/*"
      ],
      "@polygoal/db": [
        "packages/db/src/index.ts"
      ],
      "@polygoal/db/*": [
        "packages/db/src/*"
      ],
      "@polygoal/sdk": [
        "packages/sdk/src/index.ts"
      ],
      "@polygoal/sdk/*": [
        "packages/sdk/src/*"
      ],
      "@polygoal/odds-ingestion": [
        "packages/odds-ingestion/src/index.ts"
      ],
      "@polygoal/odds-ingestion/*": [
        "packages/odds-ingestion/src/*"
      ]
    },
    "ignoreDeprecations": "6.0",
    "types": [
      "bun"
    ]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "contracts/out",
    "contracts/cache",
    ".next"
  ]
}
